# ─────────────────────────────────────────────
# API & AI - 예시 파일
# 이 파일을 .env 로 복사한 후 값을 입력하세요.
# Vercel 배포 시 프로젝트 설정 > Environment Variables 에서 동일 이름으로 등록.
# ─────────────────────────────────────────────

# 백엔드 API 주소 (로컬 기본값, 배포 시 백엔드 실제 URL로 설정)
# VITE_API_URL=https://your-backend.example.com

# Anthropic Claude  (https://console.anthropic.com)
VITE_CLAUDE_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI            (https://platform.openai.com/api-keys)
VITE_OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini     (https://aistudio.google.com/app/apikey)
VITE_GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx

# 기본 제공사 선택: claude | openai | gemini
VITE_AI_DEFAULT_PROVIDER=claude
